{
  "name": "@perps/hip4",
  "version": "1.2.0",
  "description": "TypeScript SDK for Hyperliquid HIP-4 prediction markets",
  "repository": {
    "type": "git",
    "url": "https://github.com/perps-studio/hip-4.git"
  },
  "homepage": "https://github.com/perps-studio/hip-4#readme",
  "bugs": {
    "url": "https://github.com/perps-studio/hip-4/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/types.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "hyperliquid",
    "hip4",
    "hip-4",
    "prediction-markets",
    "binary-outcomes",
    "eip712",
    "sdk",
    "typescript",
    "web3"
  ],
  "author": "Dennis Furrer",
  "license": "BUSL-1.1",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
