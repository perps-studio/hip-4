{
  "name": "@perps/hip4",
  "version": "1.0.5",
  "description": "Plug & play SDK for Hyperliquid HIP-4 prediction markets.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/types.cjs"
      }
    },
    "./hooks": {
      "import": {
        "types": "./dist/hooks/index.d.ts",
        "default": "./dist/hooks.js"
      },
      "require": {
        "types": "./dist/hooks/index.d.cts",
        "default": "./dist/hooks.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hyperliquid",
    "hip4",
    "hip-4",
    "prediction-markets",
    "binary-outcomes",
    "eip712",
    "sdk",
    "typescript",
    "web3"
  ],
  "author": "Dennis Furrer",
  "license": "BUSL-1.1",
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
